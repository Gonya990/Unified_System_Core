#!/usr/bin/expect
set timeout -1
set password "Gonya990"

# Copy the entire Projects/AI_Core directory to the Desktop of the remote machine
# Using relative path on remote to land in C:\Users\gonya\Desktop\Projects/AI_Core
spawn scp -r -o StrictHostKeyChecking=no /home/kosta/Documents/Unified_System_Core/Projects/AI_Core gonya@100.127.194.111:Desktop/

expect {
  "password:" { send "$password\r"; exp_continue }
  eof
}
