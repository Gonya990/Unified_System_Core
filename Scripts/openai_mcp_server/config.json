{
    "server": {
        "host": "127.0.0.1",
        "port": 8766,
        "protocol": "http"
    },
    "openai": {
        "model": "gpt-4",
        "fallback_model": "gpt-3.5-turbo",
        "max_tokens": 4000,
        "temperature": 0.7,
        "timeout_seconds": 30
    },
    "features": {
        "conversation_sync": true,
        "custom_instructions": true,
        "shared_memory": true,
        "rate_limiting": true
    },
    "rate_limiting": {
        "requests_per_minute": 60,
        "tokens_per_minute": 90000,
        "max_concurrent_requests": 5
    },
    "logging": {
        "level": "INFO",
        "file": "logs/openai-mcp.log",
        "rotate": true,
        "max_size_mb": 10
    },
    "cache": {
        "enabled": true,
        "ttl_seconds": 300,
        "max_size_mb": 100
    }
}