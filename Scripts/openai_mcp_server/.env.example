# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-key-here

# MCP Server Settings
MCP_HOST=127.0.0.1
MCP_PORT=8766

# OpenAI Settings
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.7

# Features
ENABLE_CONVERSATION_SYNC=true
ENABLE_CUSTOM_INSTRUCTIONS=true
ENABLE_SHARED_MEMORY=true

# Security
MCP_AUTH_TOKEN=generate-random-token-here
