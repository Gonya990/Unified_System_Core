#!/usr/bin/expect
set timeout 600
set password "GarYk6550"
set host "gonya@100.127.194.111"

send_user "\nPulling Llama3.2 model on Windows...\n"
spawn ssh -o StrictHostKeyChecking=no $host "ollama pull llama3.2"
expect {
    "password:" { send "$password\r"; exp_continue }
    "success" { send_user "\nModel pulled successfully.\n" }
    eof
}
catch wait
