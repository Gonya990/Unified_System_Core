# install_all.ps1 — Универсальная установка (Windows, WSL, Docker Desktop, подготовка моделей)
# Запускайте из PowerShell с правами Administrator.

Set-StrictMode -Version Latest
Write-Host "Start install_all.ps1"

# 1) Создать папку для моделей на D:
$modelsPath = "D:\models"
if (-not (Test-Path $modelsPath)) {
    New-Item -ItemType Directory -Path $modelsPath -Force | Out-Null
    Write-Host "Created $modelsPath"
} else {
    Write-Host "$modelsPath already exists"
}

# 2) Убедиться, что WSL включен (мы уже сделали ранее)
Write-Host "Check WSL status..."
wsl --list --verbose 2>$null | Out-Null

# 3) Установить Docker Desktop через winget (если доступен)
function Install-DockerDesktop {
    Write-Host "Checking winget..."
    if (Get-Command winget -ErrorAction SilentlyContinue) {
        Write-Host "Installing Docker Desktop via winget..."
        winget install --silent --accept-package-agreements --accept-source-agreements Docker.DockerDesktop
        Write-Host "Installation command issued. Please finish installer if GUI interaction appears."
    } else {
        Write-Host "winget not found. Please download + install Docker Desktop manually from:"
        Write-Host "https://desktop.docker.com/win/main/amd64/Docker%20Desktop%20Installer.exe"
    }
}
Install-DockerDesktop

Write-Host "`nIMPORTANT: After Docker Desktop is installed, open Docker Desktop UI and enable Settings → Resources → WSL Integration → Enable for distribution 'Ubuntu'."
Write-Host "Then come back and run this script's WSL part (below) or simply press Enter to continue now (if integration already enabled)."
Read-Host -Prompt "Press Enter to continue when done (or Ctrl+C to abort)"

# 4) Shutdown WSL (to apply integration)
Write-Host "Shutting down WSL..."
wsl --shutdown
Start-Sleep -Seconds 3

# 5) Copy quick_install scripts into Windows path if not present (assumes repo in C:\Users\gonya\my-ai-project)
$repo = "C:\Users\gonya\my-ai-project"
if (-not (Test-Path $repo)) {
    Write-Host "Repository path $repo not found. Please clone repo to that path and re-run."
    exit 1
}

# 6) Запустить wsl_setup.sh внутри WSL (выполнит apt update, установит nvidia-docker2 и т.п.)
$wslScript = "/mnt/c/Users/gonya/my-ai-project/quick_install/wsl_setup.sh"
Write-Host "Running WSL setup script: $wslScript"
# Убедимся, что файл существует
if (-not (Test-Path "C:\Users\gonya\my-ai-project\quick_install\wsl_setup.sh")) {
    Write-Host "WSL setup script not found at C:\Users\gonya\my-ai-project\quick_install\wsl_setup.sh"
    exit 1
}
# Выполнение в WSL
wsl -d Ubuntu -- bash -lc "chmod +x $wslScript && sudo bash -lc '$wslScript'"

Write-Host "`nWSL setup script finished. Now create directories on /mnt/d for models and symlink in repo."

# 7) Создать папки на /mnt/d через WSL и симлинк в проекте (в WSL)
wsl -d Ubuntu -- bash -lc "sudo mkdir -p /mnt/d/models/{sd,llm,shared} || true; sudo chown -R $(id -u):$(id -g) /mnt/d/models || true; cd /mnt/c/Users/gonya/my-ai-project || exit 1; rm -f models || true; ln -s /mnt/d/models models || true; ls -la models"

Write-Host "`nAll preparation steps finished. Next steps:"
Write-Host " - Ensure Docker Desktop is running and WSL integration is enabled for Ubuntu."
Write-Host " - In WSL (or via this script's next commands), run: docker compose up --build -d (from repo root)."
Write-Host "Running docker compose now (attempt)..."
wsl -d Ubuntu -- bash -lc "cd /mnt/c/Users/gonya/my-ai-project || exit 1; docker compose up --build -d || echo 'docker compose failed — ensure Docker Desktop is running and integration enabled'"

Write-Host "`nFinished install_all.ps1"