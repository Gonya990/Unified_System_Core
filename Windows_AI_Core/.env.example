# AI Telegram Bot Environment Configuration
# Copy this file to .env and fill in the values

# Required: Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=

# Inference Backend Configuration
INFERENCE_BASE_URL=http://localhost:11434
INFERENCE_API_KEY=
MODEL_NAME=llama3.2

# Logging
LOG_LEVEL=INFO

# Container versioning (optional)
VERSION=latest
