{
  "version": "1.0",
  "minConfidenceScore": 3,
  "maxSkillsToShow": 5,
  "directoryMappings": {
    "Agent_Context/agents": "agent-development",
    "Agent_Context/Knowledge_Base": "knowledge-management",
    "Scripts": "automation",
    ".agent/workflows": "workflow-development",
    ".claude/skills": "skill-development",
    ".claude/commands": "command-development",
    ".github/workflows": "github-actions"
  },
  "skills": {
    "systematic-debugging": {
      "description": "Four-phase debugging framework with root cause analysis",
      "keywords": ["debug", "bug", "error", "fix", "broken", "not working", "failing", "crash"],
      "keywordPatterns": ["(why|what).*(fail|error|broken|crash)", "investigate.*issue"],
      "intentPatterns": ["fix.*bug", "debug.*problem", "find.*cause"]
    },
    "testing-patterns": {
      "description": "TDD workflow, test factories, and assertion patterns",
      "keywords": ["test", "spec", "mock", "stub", "fixture", "assertion", "expect", "jest", "pytest"],
      "pathPatterns": ["*.test.*", "*.spec.*", "__tests__/*", "test_*.py"],
      "intentPatterns": ["write.*test", "add.*test", "test.*coverage"]
    },
    "code-review": {
      "description": "Systematic code review checklist and patterns",
      "keywords": ["review", "pr", "pull request", "feedback", "quality"],
      "intentPatterns": ["review.*code", "check.*implementation", "give.*feedback"]
    },
    "git-workflow": {
      "description": "Branch naming, commit conventions, PR creation",
      "keywords": ["commit", "branch", "merge", "rebase", "git", "push", "pull"],
      "intentPatterns": ["create.*branch", "commit.*changes", "make.*pr", "open.*pull"]
    },
    "agent-development": {
      "description": "Creating and configuring AI agent definitions",
      "keywords": ["agent", "subagent", "orchestration", "delegation"],
      "pathPatterns": [".claude/agents/*", "Agent_Context/agents/*"],
      "intentPatterns": ["create.*agent", "new.*agent", "agent.*definition"]
    },
    "workflow-development": {
      "description": "Creating reusable workflow definitions",
      "keywords": ["workflow", "automation", "script", "task"],
      "pathPatterns": [".agent/workflows/*"],
      "intentPatterns": ["create.*workflow", "automate.*task"]
    },
    "documentation": {
      "description": "Technical writing and documentation patterns",
      "keywords": ["docs", "documentation", "readme", "guide", "tutorial"],
      "pathPatterns": ["*.md", "docs/*", "README*"],
      "intentPatterns": ["write.*doc", "update.*readme", "document.*feature"]
    },
    "github-actions": {
      "description": "CI/CD workflow configuration and patterns",
      "keywords": ["ci", "cd", "workflow", "action", "pipeline", "deploy"],
      "pathPatterns": [".github/workflows/*", "*.yml"],
      "intentPatterns": ["ci.*pipeline", "github.*action", "automate.*deploy"]
    },
    "python-patterns": {
      "description": "Python best practices and idioms",
      "keywords": ["python", "pip", "venv", "pytest", "django", "flask"],
      "pathPatterns": ["*.py", "requirements*.txt", "pyproject.toml"],
      "intentPatterns": ["python.*code", "create.*script"]
    },
    "typescript-patterns": {
      "description": "TypeScript conventions and type safety",
      "keywords": ["typescript", "type", "interface", "generic", "tsconfig"],
      "pathPatterns": ["*.ts", "*.tsx", "tsconfig.json"],
      "intentPatterns": ["type.*definition", "typescript.*code"]
    },
    "verification-before-completion": {
      "description": "Quality gates and verification checklist before marking done",
      "keywords": ["verify", "check", "validate", "confirm", "ensure"],
      "intentPatterns": ["before.*done", "make.*sure", "verify.*works"]
    },
    "beads-task-management": {
      "description": "Using Beads for task tracking and coordination",
      "keywords": ["beads", "task", "issue", "ticket", "bd"],
      "intentPatterns": ["create.*task", "track.*work", "manage.*issue"]
    }
  }
}
