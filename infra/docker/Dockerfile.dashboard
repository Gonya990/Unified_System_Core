FROM node:20-slim AS builder
WORKDIR /app
COPY Projects/ChatKit_Dashboard/package*.json ./
RUN npm install
COPY Projects/ChatKit_Dashboard/ ./
RUN npm run build || echo "Build failed, but proceeding for dev mode"

FROM node:20-slim
WORKDIR /app
COPY --from=builder /app ./
ENV NODE_ENV=production
EXPOSE 3000
CMD ["npm", "run", "start"]
