# Unified System Core - Environment Configuration
# Copy this file to .env and fill in the values

# ============================================
# GENERAL SETTINGS
# ============================================

TZ=UTC
LOG_LEVEL=INFO

# ============================================
# AI TELEGRAM BOT
# ============================================

# Required: Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=

# Required: Your Telegram user ID (get from @userinfobot)
ADMIN_ID=

# Optional: Comma-separated list of allowed user IDs
ALLOWED_USERS=

# Inference provider: ollama, openai, gemini, anthropic
INFERENCE_PROVIDER=ollama

# For local Ollama
INFERENCE_BASE_URL=http://ollama:11434
MODEL_NAME=llama3.2

# Image tag for AI Bot container
AI_BOT_TAG=latest

# ============================================
# API KEYS (fill only what you need)
# ============================================

# OpenAI API Key (for GPT models)
OPENAI_API_KEY=

# Google Gemini API Key
GEMINI_API_KEY=

# Anthropic API Key (for Claude)
ANTHROPIC_API_KEY=

# OpenRouter API Key (multi-model gateway)
OPENROUTER_API_KEY=

# ============================================
# AGENT MAIL SYSTEM
# ============================================

# Required: Bearer token for Agent Mail API
AGENT_MAIL_TOKEN=

# Agent identity
AGENT_MAIL_NAME=VioletCastle
AGENT_MAIL_SERVER=http://agent-mail-server:8765

# PostgreSQL password for Agent Mail DB
POSTGRES_PASSWORD=change_me_in_production

# Poll interval in seconds
POLL_INTERVAL=60

# Image tags
AGENT_MAIL_TAG=latest
MAIL_PROCESSOR_TAG=latest

# ============================================
# MCP SERVERS
# ============================================

OPENAI_MCP_TAG=latest
ANTIGRAVITY_MCP_TAG=latest
CLIPROXY_TAG=latest

# ============================================
# WEB APPLICATIONS
# ============================================

CHATKIT_TAG=latest
LANDING_TAG=latest

# ============================================
# PORTS (change if conflicts)
# ============================================

# AI Bot ports
AI_BOT_HEALTH_PORT=8080
AI_BOT_BRIDGE_PORT=8090
AI_BOT_DASHBOARD_PORT=8095

# Service ports
AGENT_MAIL_PORT=8765
OPENAI_MCP_PORT=8766
ANTIGRAVITY_MCP_PORT=3005
CLIPROXY_PORT=8317
CHATKIT_PORT=3001
LANDING_PORT=3002

# Inference ports
OLLAMA_PORT=11434
WEBUI_PORT=3003

# ============================================
# INFRASTRUCTURE
# ============================================

# Watchtower poll interval (seconds)
WATCHTOWER_INTERVAL=300
