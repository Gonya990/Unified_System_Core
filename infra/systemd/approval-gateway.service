[Unit]
Description=Unified Core Approval Gateway (YubiKey / policy)
After=network-online.target

[Service]
Type=simple
User=unified
WorkingDirectory=/opt/unified/guardrails
Environment=PYTHONPATH=/opt/unified/guardrails/services/policy-engine
ExecStart=/opt/unified/guardrails/.venv/bin/uvicorn app.main:app --app-dir services/approval-gateway --host 127.0.0.1 --port 8790
Restart=on-failure

[Install]
WantedBy=multi-user.target
