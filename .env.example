# Unified System Core - Environment Configuration
# Copy this file to .env and fill in the values

# ===========================================
# Telegram Bot Configuration (Required)
# ===========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_IDS=708531393,1881720235

# ===========================================
# Inference Configuration
# ===========================================
# Provider: ollama, openrouter, openai, council
INFERENCE_PROVIDER=ollama
INFERENCE_BASE_URL=http://host.docker.internal:11434
INFERENCE_API_KEY=
MODEL_NAME=llama3.2

# OpenRouter (optional - for cloud inference)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ===========================================
# AI Provider API Keys (for LLM Council)
# ===========================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ===========================================
# GCP Monitoring (optional)
# ===========================================
GCP_PROJECT=gen-lang-client-0982257437
INSTANCE_NAME=igor-gaming-1
COLLECTION_INTERVAL=60

# ===========================================
# Application Settings
# ===========================================
LOG_LEVEL=INFO
VERSION=latest
