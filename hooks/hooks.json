{
  "description": "Agent Mail notification hook - reminds agent to check mail after subagent tasks",
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-mail.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
