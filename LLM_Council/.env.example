# ==========================================
# LLM COUNCIL CONFIGURATION
# ==========================================
# Copy to .env and fill in your API keys

# ------------------------------------------
# OPENAI (Required for GPT models)
# ------------------------------------------
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# ------------------------------------------
# GITHUB COPILOT (Optional)
# Get token: https://github.com/settings/tokens
# ------------------------------------------
GITHUB_TOKEN=ghp_your-token-here
GITHUB_COPILOT_MODEL=gpt-4o

# ------------------------------------------
# NVIDIA NIM (Optional)
# Get key: https://build.nvidia.com
# ------------------------------------------
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# ------------------------------------------
# COUNCIL SETTINGS
# ------------------------------------------
# Which LLM acts as Chairman (synthesizes final answer)
CHAIRMAN_PROVIDER=openai
CHAIRMAN_MODEL=gpt-4o

# Enable/disable providers in council
COUNCIL_PROVIDERS=openai,nvidia
# Options: openai,github,nvidia (comma-separated)

# Peer review settings
ENABLE_PEER_REVIEW=true
PEER_REVIEW_MODEL=gpt-4o-mini

# ------------------------------------------
# OPTIONAL: Store conversations (for memory)
# ------------------------------------------
OPENAI_STORE=true
SAVE_COUNCIL_HISTORY=true
HISTORY_DIR=./council_history

# ------------------------------------------
# LOGGING
# ------------------------------------------
LOG_LEVEL=INFO
