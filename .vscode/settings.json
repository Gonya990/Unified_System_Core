{
    "gitlens.launchpad.enabled": true,
    "gitlens.launchpad.indicator.enabled": true,
    "gitlens.launchpad.indicator.label": "item",
    "gitlens.launchpad.indicator.useIcons": true,
    "gitlens.launchpad.views.pullRequests.enabled": true,
