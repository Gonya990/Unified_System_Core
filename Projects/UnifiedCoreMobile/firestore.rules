rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /chats/{chatId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
                    && request.resource.data.sender == 'user' 
                    && request.resource.data.deviceId == request.auth.uid;
      allow update, delete: if false;
    }
    
    // Relay Collections
    match /mobile_commands/{document=**} {
      allow create: if true;
      allow read, update: if true;
    }
    match /mobile_responses/{document=**} {
      allow read: if true;
    }
    match /system_status/{document=**} {
      allow read: if true;
    }
    match /ha_states/{document=**} {
      allow read: if true;
    }
    match /system_logs/{document=**} {
      allow read: if true;
    }
  }
}
