# Kubernetes Secrets Template for AI Telegram Bot
#
# USAGE:
#   1. Copy this file to secrets.yaml
#   2. Fill in the base64-encoded values
#   3. Apply: kubectl apply -f secrets.yaml
#
# To encode values:
#   echo -n "your-value" | base64
#
# IMPORTANT: Never commit secrets.yaml to version control!

apiVersion: v1
kind: Secret
metadata:
  name: telegram-bot-secrets
  namespace: telegram-bot
  labels:
    app: ai-telegram-bot
    app.kubernetes.io/name: ai-telegram-bot
    app.kubernetes.io/component: secrets
type: Opaque
data:
  # Required: Telegram Bot Token
  # echo -n "123456789:AAHdqTcvCH1vGWJxfSeofSAs0K5PALDsaw" | base64
  TELEGRAM_BOT_TOKEN: ""

  # Required: Admin Telegram User ID
  # echo -n "708531393" | base64
  ADMIN_ID: ""

  # Optional: Comma-separated allowed user IDs
  # echo -n "708531393,5569219290" | base64
  ALLOWED_USERS: ""

  # Optional: OpenAI API Key
  # echo -n "sk-..." | base64
  OPENAI_API_KEY: ""

  # Optional: Gemini API Key
  # echo -n "AIza..." | base64
  GEMINI_API_KEY: ""

  # Optional: Anthropic API Key
  # echo -n "sk-ant-..." | base64
  ANTHROPIC_API_KEY: ""

  # Optional: Inference API Key (if using authenticated endpoint)
  # echo -n "your-api-key" | base64
  INFERENCE_API_KEY: ""

---
