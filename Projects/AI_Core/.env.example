# AI Telegram Bot Environment Configuration
# Copy this file to .env and fill in the values

# Required: Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=

# ==============================================
# INFERENCE PROVIDER CONFIGURATION
# ==============================================
# Supported providers: ollama, openai, gemini
INFERENCE_PROVIDER=ollama

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4o-mini

# Gemini Configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ==============================================
# LEGACY SETTINGS (for backward compatibility)
# ==============================================
INFERENCE_BASE_URL=http://localhost:11434
INFERENCE_API_KEY=
MODEL_NAME=llama3.2

# Logging
LOG_LEVEL=INFO

# ==============================================
# GOOGLE CALENDAR
# ==============================================
# Path to Google OAuth credentials JSON file
# Copy credentials.example/google_token.json.example to credentials/google_token.json
# and fill in your OAuth credentials
GOOGLE_CREDENTIALS_PATH=./credentials/google_token.json

# Container versioning (optional)
VERSION=latest
